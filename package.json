{
  "name": "jeanclaw",
  "version": "0.1.0",
  "description": "Claude Code wrapper — turn your Max subscription into a programmable AI assistant via Telegram, iMessage, and HTTP",
  "type": "module",
  "bin": {
    "jeanclaw": "./dist/bin/jeanclaw.js"
  },
  "files": [
    "dist/",
    "templates/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/bin/jeanclaw.js start",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "claude",
    "ai",
    "telegram",
    "assistant",
    "openclaw",
    "jeanclaw"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidstroiazzo/jeanclaw"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "croner": "^9.0.0",
    "grammy": "^1.35.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
